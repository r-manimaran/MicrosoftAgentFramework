{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Ingestion": {
    "MdFilesRootPath": "./md-files",
    "MaxTokenPerChunk": 512,
    "ChunkOverlapTokens": 64,
    "EmbeddingBatchSize": 100,
    "MaxConcurrentIngestions": 3,
    "FileChangeDebounce": "00:00:02",
    "MaxEmbeddingRetries": 5
  },
  "Qdrant": {
    "CollectionName": "md-documents",
    "VectorDimensions": 3072,
    "SparseVectorName": "bm25"
  }
}
